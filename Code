function getSheet(name) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName(name);
  if (!sheet) sheet = ss.insertSheet(name);
  return sheet;
}

function formatDate(date) {
  if (!date) return '';
  const d = new Date(date);
  return Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyy-MM-dd');
}

function callGeminiApi(base64, mimeType) {
  if (!GEMINI_API_KEY) return {};
  const url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + GEMINI_API_KEY;
  const prompt = "領収書画像解析。JSON出力。項目:use_date(YYYY-MM-DD),store_name,total_amount(数値),item_name,category,has_invoice(bool),client,participants(文字列),participant_count(数値:合計人数),guest_count(数値:接待相手人数),host_count(数値:自社側人数),summary_text";
  const payload = { contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType: mimeType, data: base64 } }] }] };
  try {
    const res = UrlFetchApp.fetch(url, { method: 'post', contentType: 'application/json', payload: JSON.stringify(payload), muteHttpExceptions: true });
    const json = JSON.parse(res.getContentText());
    if (!json.candidates) return {};
    const text = json.candidates[0].content.parts[0].text;
    return JSON.parse(text.replace(/```json|```/g, '').trim());
  } catch (e) { return {}; }
}

// 照合情報を取得するために関数更新
function getHistoryData(filter) {
  try {
    const rSheet = getSheet(SHEETS.RECEIPTS), dSheet = getSheet(SHEETS.DETAILS);
    const sSheet = getSheet(SHEETS.CARD_STATEMENT); // 照合確認用
    
    if (rSheet.getLastRow() <= 1) return [];
    const data = rSheet.getDataRange().getValues().slice(1);
    const dData = dSheet.getDataRange().getLastRow() > 1 ? dSheet.getDataRange().getValues().slice(1) : [];
    
    // 照合済みデータのマップを作成 (領収書ID -> true)
    const reconciledMap = {};
    if (sSheet.getLastRow() > 1) {
        const sData = sSheet.getDataRange().getValues().slice(1);
        sData.forEach(row => {
            const linkId = String(row[COLS_STATEMENT.LINK_ID]); // 紐付け領収書ID
            if(linkId) reconciledMap[linkId] = true;
        });
    }

    const detailMap = {};
    dData.forEach(d => {
      const pid = String(d[1]);
      if(!detailMap[pid]) detailMap[pid] = [];
      detailMap[pid].push({ category: d[2], item: d[3], amount: d[4] });
    });
    const dupMap = {};
    data.forEach(row => {
      const k = formatDate(row[COLS_FINAL.USE_DATE]) + "_" + String(row[COLS_FINAL.STORE]).trim() + "_" + Number(row[COLS_FINAL.AMOUNT]);
      dupMap[k] = (dupMap[k] || 0) + 1;
    });
    
    let rows = data.map(row => {
      const mStatus = row[COLS_FINAL.ADMIN_CHECK], nStatus = row[COLS_FINAL.PRESIDENT_CHECK];
      let ds = 'draft';
      if (nStatus === STATUS.PENDING) ds = 'pending';
      else if (nStatus === STATUS.APPROVED) ds = mStatus === STATUS.EXPORTED ? 'exported' : (mStatus === STATUS.CHECKED ? 'checked' : 'approved');
      else if (nStatus === STATUS.REJECTED) ds = 'rejected';
      return {
        id: row[COLS_FINAL.ID], date: formatDate(row[COLS_FINAL.USE_DATE]), user: row[COLS_FINAL.USER], store: row[COLS_FINAL.STORE], amount: row[COLS_FINAL.AMOUNT],
        status: ds, items: detailMap[String(row[COLS_FINAL.ID])] || [], fileId: row[COLS_FINAL.FILE_ID], 
        isDuplicate: (dupMap[formatDate(row[COLS_FINAL.USE_DATE]) + "_" + String(row[COLS_FINAL.STORE]).trim() + "_" + Number(row[COLS_FINAL.AMOUNT])] > 1),
        isReconciled: !!reconciledMap[row[COLS_FINAL.ID]] // 照合ステータス
      };
    });
    if (filter.view === 'history' && !['経理', '管理者', '社長'].includes(filter.role)) rows = rows.filter(r => r.user === filter.userName);
    else if (filter.view === 'president') rows = rows.filter(r => r.status === 'pending');
    else if (filter.view === 'admin') rows = rows.filter(r => r.status === 'approved' || r.status === 'checked');
    return rows.reverse();
  } catch (e) { return []; }
}

function submitBulkApplications(ids) { return updateStatusBulk(ids, STATUS.PENDING, 'president'); }
function approveBulk(ids) { return updateStatusBulk(ids, STATUS.APPROVED, 'president'); }
function checkBulk(ids) { return updateStatusBulk(ids, STATUS.CHECKED, 'admin'); }
function updateStatusBulk(ids, newStatus, type) {
  const sheet = getSheet(SHEETS.RECEIPTS), data = sheet.getDataRange().getValues();
  const col = type === 'president' ? COLS_FINAL.PRESIDENT_CHECK : COLS_FINAL.ADMIN_CHECK;
  ids.forEach(id => {
    for(let i=1; i<data.length; i++) if(String(data[i][COLS_FINAL.ID]) === String(id)) {
      sheet.getRange(i+1, col + 1).setValue(newStatus);
      if(newStatus === STATUS.PENDING) sheet.getRange(i+1, COLS_FINAL.ADMIN_CHECK + 1).setValue('未チェック');
    }
  });
  return { success: true };
}

function deleteApplication(id) {
  const rSheet = getSheet(SHEETS.RECEIPTS), dSheet = getSheet(SHEETS.DETAILS);
  const rData = rSheet.getDataRange().getValues();
  for(let i=rData.length-1; i>=1; i--) if(String(rData[i][COLS_FINAL.ID]) === String(id)) rSheet.deleteRow(i+1);
  const dData = dSheet.getDataRange().getValues();
  for(let i=dData.length-1; i>=1; i--) if(String(dData[i][1]) === String(id)) dSheet.deleteRow(i+1);
  return { success: true };
}

function rejectBulkWithComment(ids, comment) {
    const rSheet = getSheet(SHEETS.RECEIPTS), data = rSheet.getDataRange().getValues();
    ids.forEach(id => {
        for(let i=1; i<data.length; i++) if(String(data[i][COLS_FINAL.ID]) === String(id)) {
            rSheet.getRange(i+1, COLS_FINAL.PRESIDENT_CHECK + 1).setValue(STATUS.REJECTED);
            rSheet.getRange(i+1, COLS_FINAL.REJECT_COMMENT + 1).setValue(comment);
        }
    });
    return { success: true };
}

// ...カード明細照合機能...
function uploadStatementAndAnalyze(fileData) {
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(30000)) throw new Error('サーバーが混み合っています。');
  try {
    const aiResult = callGeminiForStatement(fileData.base64, fileData.mimeType);
    if (!aiResult.items || aiResult.items.length === 0) throw new Error('明細データが見つかりませんでした');

    let detectedUser = '不明';
    let detectedCard = String(aiResult.card_last4 || '').trim();
    if (detectedCard || aiResult.card_holder) {
       const uSheet = getSheet(SHEETS.USERS);
       const uData = uSheet.getDataRange().getValues();
       for(let i=1; i<uData.length; i++) {
         const rowCardInfo = String(uData[i][2] || ''); 
         const rowName = String(uData[i][0] || '');
         if ((detectedCard && rowCardInfo.includes(detectedCard)) || 
             (aiResult.card_holder && rowName.includes(aiResult.card_holder))) {
             detectedUser = rowName;
             const match = rowCardInfo.match(/\d{4}/);
             if(match) detectedCard = match[0];
             break;
         }
       }
    }

    const sSheet = getSheet(SHEETS.CARD_STATEMENT);
    const now = new Date();
    const newRows = aiResult.items.map(item => {
       return [
         Utilities.getUuid(), 
         now,                 
         detectedCard,        
         aiResult.card_holder || detectedUser, 
         item.date,           
         item.store,          
         Number(item.amount), 
         '未照合',            
         ''                   
       ];
    });

    sSheet.getRange(sSheet.getLastRow() + 1, 1, newRows.length, newRows[0].length).setValues(newRows);
    return { success: true, count: newRows.length, user: detectedUser, card: detectedCard };

  } catch(e) { throw new Error(e.message); } finally { lock.releaseLock(); }
}

// 照合データの取得（フィルタ対応）
function getReconciliationData(viewMode) {
  const sSheet = getSheet(SHEETS.CARD_STATEMENT);
  if (sSheet.getLastRow() <= 1) return [];
  const sData = sSheet.getDataRange().getValues().slice(1);
  
  // viewMode === 'all' なら全件、それ以外('unmatched')なら未照合のみ
  const statements = sData.filter(r => viewMode === 'all' || r[COLS_STATEMENT.STATUS] !== '照合済').map(r => ({
     id: r[COLS_STATEMENT.ID],
     card: r[COLS_STATEMENT.CARD_NUM],
     holder: r[COLS_STATEMENT.HOLDER],
     date: formatDate(r[COLS_STATEMENT.DATE]),
     store: r[COLS_STATEMENT.STORE],
     amount: Number(r[COLS_STATEMENT.AMOUNT]),
     status: r[COLS_STATEMENT.STATUS]
  }));

  const rSheet = getSheet(SHEETS.RECEIPTS);
  const rData = rSheet.getDataRange().getValues().slice(1);
  const receipts = rData.map(r => ({
     id: r[COLS_FINAL.ID],
     date: formatDate(r[COLS_FINAL.USE_DATE]),
     user: r[COLS_FINAL.USER],
     store: r[COLS_FINAL.STORE],
     amount: Number(r[COLS_FINAL.AMOUNT]),
     cardName: r[COLS_FINAL.CARD_NAME]
  }));

  statements.forEach(stmt => {
      // 照合済みなら候補計算スキップ
      if(stmt.status === '照合済') {
          stmt.candidates = [];
          return;
      }

      const candidates = receipts.filter(rcpt => {
          const isAmountMatch = rcpt.amount === stmt.amount;
          return isAmountMatch; 
      });

      if (candidates.length > 0) {
          stmt.candidates = candidates;
          if (candidates.some(c => stmt.holder.includes(c.user))) {
             stmt.status = '候補あり';
          }
      } else {
          stmt.candidates = [];
      }
  });

  return statements.reverse(); // 新しい順
}

// 紐付け実行関数
function linkStatementToReceipt(statementId, receiptId) {
    const sSheet = getSheet(SHEETS.CARD_STATEMENT);
    const data = sSheet.getDataRange().getValues();
    for(let i=1; i<data.length; i++) {
        if(String(data[i][COLS_STATEMENT.ID]) === String(statementId)) {
            sSheet.getRange(i+1, COLS_STATEMENT.STATUS + 1).setValue('照合済');
            sSheet.getRange(i+1, COLS_STATEMENT.LINK_ID + 1).setValue(receiptId);
            return { success: true };
        }
    }
    return { success: false };
}

function callGeminiForStatement(base64, mimeType) {
  if (!GEMINI_API_KEY) return {};
  const url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + GEMINI_API_KEY;
  const prompt = "クレジットカード利用明細書の画像を解析してください。JSON出力。項目: card_last4(カード番号下4桁), card_holder(名義人), items:[{date(YYYY-MM-DD), store(店名), amount(数値)}]. ヘッダーや合計行は無視してください。";
  const payload = { contents: [{ parts: [{ text: prompt }, { inlineData: { mimeType: mimeType, data: base64 } }] }] };
  try {
    const res = UrlFetchApp.fetch(url, { method: 'post', contentType: 'application/json', payload: JSON.stringify(payload), muteHttpExceptions: true });
    const json = JSON.parse(res.getContentText());
    const text = json.candidates[0].content.parts[0].text;
    return JSON.parse(text.replace(/```json|```/g, '').trim());
  } catch (e) { return { items: [] }; }
}
