function getCurrentUser(savedName) {
  try {
    const activeUserEmail = Session.getActiveUser().getEmail();
    const guestUser = { name: 'ゲスト', email: activeUserEmail || 'unknown', role: '一般', card: '', dept: '', canFix: false, isGuest: true };
    const sheet = getSheet(SHEETS.USERS);
    const data = sheet.getDataRange().getValues();
    if (data.length <= 1) return guestUser;
    
    if (activeUserEmail) {
      for (let i = 1; i < data.length; i++) {
        const row = data[i];
        if (String(row[3] || "").trim().toLowerCase() === activeUserEmail.toLowerCase()) {
          return { name: String(row[0]||""), email: activeUserEmail, role: String(row[1]||"一般"), card: String(row[2]||""), dept: String(row[4]||""), canFix: true, isGuest: false };
        }
      }
    }
    if (savedName) {
      for (let i = 1; i < data.length; i++) {
        const row = data[i];
        if (String(row[0] || "").trim() === savedName) {
          return { name: savedName, email: activeUserEmail||String(row[3]||""), role: String(row[1]||"一般"), card: String(row[2]||""), dept: String(row[4]||""), canFix: true, isGuest: false };
        }
      }
    }
    return guestUser;
  } catch (e) {
    console.error("User Fetch Error: " + e.message);
    return { name: 'システムエラー', email: '', role: 'Error', error: e.message };
  }
}

