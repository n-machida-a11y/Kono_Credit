function getFileAsBase64(fileId) {
  if (!fileId || fileId === 'NO_FILE') return null;
  try {
    const file = DriveApp.getFileById(fileId);
    const blob = file.getBlob();
    return `data:${blob.getContentType()};base64,${Utilities.base64Encode(blob.getBytes())}`;
  } catch (e) {
    console.error("File Access Error: " + e.message);
    return null;
  }
}

function getMasters() {
  try {
    const aSheet = getSheet(SHEETS.ACCOUNTS);
    const accounts = aSheet.getDataRange().getValues().slice(1).map(r => String(r[1] || '')).filter(Boolean);
    const uSheet = getSheet(SHEETS.USERS);
    const users = uSheet.getDataRange().getValues().slice(1).map(r => String(r[0] || '')).filter(Boolean);
    return { accounts: accounts, users: users };
