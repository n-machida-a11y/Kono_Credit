                 <div class="col-4">
                    <label class="form-label small fw-bold text-primary">税込合計</label>
                    <input type="number" class="form-control form-control-sm fw-bold text-primary editDetailAmount" value="${d.amount||''}" placeholder="合計" ${ro?'readonly':''} oninput="updateEntertainmentLogic(this)">
                 </div>
                 <div class="col-12">
                    <label class="form-label small fw-bold text-muted">詳細メモ</label>
                    <input type="text" class="form-control form-control-sm editMemo" value="${d.memo||''}" placeholder="メモ" ${ro?'readonly':''}>
                 </div>
             </div>
             ${ro?'':'<div class="text-end mt-2"><button class="btn btn-sm btn-outline-danger" onclick="detailData.splice('+i+',1);renderDetails(false)"><i class="fas fa-trash-alt me-1"></i>削除</button></div>'}
        </div>`;
