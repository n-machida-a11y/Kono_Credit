                    <input type="text" class="form-control form-control-sm editItem" value="${d.item||''}" placeholder="品目" ${ro?'readonly':''}>
                 </div>
                 <div class="col-12">
                    <label class="form-label small fw-bold text-muted">取引先</label>
                    <input type="text" class="form-control form-control-sm editClient" value="${d.client||''}" placeholder="取引先" ${ro?'readonly':''}>
                 </div>
                 <div class="col-4">
                    <label class="form-label small fw-bold text-muted">税抜</label>
                    <input type="number" class="form-control form-control-sm editNet" value="${d.net||''}" placeholder="税抜" ${ro?'readonly':''}>
                 </div>
                 <div class="col-4">
                    <label class="form-label small fw-bold text-muted">消費税</label>
