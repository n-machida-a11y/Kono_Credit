function checkEntertainment(input) {
    const val = input.value;
    const groups = input.closest('.row').querySelectorAll('.entertainment-group');
    const isEnt = val.includes('接待') || val.includes('交際');
    groups.forEach(g => {
        if (isEnt) g.classList.remove('d-none');
        else g.classList.add('d-none');
    });
}

function updateEntertainmentLogic(input) {
    const row = input.closest('.row');
    const guest = Number(row.querySelector('.editGuest').value) || 0;
    const host = Number(row.querySelector('.editHost').value) || 0;
    const totalInput = row.querySelector('.editParticipants');
    
    // 合計人数計算
    const total = guest + host;
    if (total > 0) totalInput.value = total;

    // 少額接待交際費判定
    const amount = Number(row.querySelector('.editDetailAmount').value) || 0;
    const catInput = row.querySelector('.editCat');
    const currentCat = catInput.value;

    if (currentCat.includes('接待') || currentCat.includes('交際')) {
        if (total > 0 && amount > 0) {
            const unitPrice = amount / total;
            if (unitPrice <= 10000) {
                catInput.value = '少額接待交際費';
            } else {
                catInput.value = '接待交際費';
            }
        }
    }
}

function addDetailItem() { detailData.push({category:'', item:'', amount:'', client:'', participants:'', net:'', tax:'', memo:'', place:'', guestCount:'', hostCount:''}); renderDetails(false); }

function saveData(hasNext = false) {
    const items = Array.from(document.querySelectorAll('#detailItemsContainer .detail-card')).map(c => ({
        category: c.querySelector('.editCat').value, 
        itemName: c.querySelector('.editItem').value, 
        total_price: Number(c.querySelector('.editDetailAmount').value),
        client: c.querySelector('.editClient').value,
        participants: c.querySelector('.editParticipants').value,
        net: Number(c.querySelector('.editNet').value),
        tax: Number(c.querySelector('.editTax').value),
        memo: c.querySelector('.editMemo').value,
        place: c.querySelector('.editPlace') ? c.querySelector('.editPlace').value : '',
        guestCount: c.querySelector('.editGuest') ? c.querySelector('.editGuest').value : '',
        hostCount: c.querySelector('.editHost') ? c.querySelector('.editHost').value : ''
    }));
    const payload = {
        id: document.getElementById('editId').value, useDate: document.getElementById('editDate').value, storeName: document.getElementById('editStore').value,
        totalAmount: document.getElementById('editAmount').value, hasInvoice: document.getElementById('editInvoice').checked,
        globalMemo: document.getElementById('editGlobalMemo').value, items: items
    };
    showLoading(true, '保存中...');
    google.script.run.withSuccessHandler(() => { 
        showLoading(false); 
        loadHistory(); 
        if(document.getElementById('view-admin').style.display !== 'none') loadAdminData();

        if (hasNext) {
            currentQueueIndex++;
            if (currentQueueIndex < editingQueue.length) {
                openEditFromHistory(editingQueue[currentQueueIndex], true, true);
            } else {
                editModal.hide();
            }
        } else {
            editModal.hide();
        }
    }).updateApplication(payload);
}

function renderAdminTable() {
    const tbody = document.getElementById('adminBody'), month = document.getElementById('adminFilterMonth').value, search = document.getElementById('adminFilterSearch').value.toLowerCase(), statusFilter = document.getElementById('adminFilterStatus').value;
    let filtered = historyData.filter(r => {
        const matchMonth = !month || (r.date && r.date.startsWith(month));
        const matchSearch = !search || (r.store && r.store.toLowerCase().includes(search)) || (r.user && r.user.toLowerCase().includes(search));
        const matchStatus = (statusFilter === 'all' || r.status === statusFilter);
        return matchMonth && matchSearch && matchStatus;
    });
    let html = "";
    filtered.forEach(r => {
        const badge = r.status === 'checked' ? '<span class="badge bg-info">経理チェック済</span>' : '<span class="badge bg-warning text-dark">経理未チェック</span>';
        const reconciledMark = r.isReconciled ? '<i class="fas fa-check-circle text-success" title="カード明細と照合済"></i>' : '<span class="text-muted">-</span>';
        
        html += `<tr style="cursor:pointer" onclick="openEditFromHistory('${r.id}', true)">
            <td onclick="event.stopPropagation()"><input type="checkbox" class="admin-check" value="${r.id}"></td>
            <td><button class="btn btn-outline-primary btn-edit-unify" onclick="event.stopPropagation(); openEditFromHistory('${r.id}', true)"><i class="fas fa-edit me-1"></i>修正・確認</button></td>
            <td>${r.date}</td><td>${r.user}</td><td><b>${r.store}</b></td><td><small>${r.items[0]?r.items[0].category:'-'}</small></td>
            <td class="text-end fw-bold">¥${Number(r.amount).toLocaleString()}</td>
            <td class="text-center">${reconciledMark}</td>
            <td class="text-center">${badge}</td></tr>`;
    });
    tbody.innerHTML = html;
    document.getElementById('adminDisplayCount').textContent = filtered.length;
}

function loadAdminData() { showLoading(true); google.script.run.withSuccessHandler(data => { showLoading(false); historyData = data; renderAdminTable(); }).getHistoryData({view: 'admin'}); }
function processAdminAction(func) {
    const ids = Array.from(document.querySelectorAll('.admin-check:checked')).map(c => c.value);
    if(!ids.length) return alert('選択してください');
    if(!confirm('実行しますか？')) return;
    showLoading(true); google.script.run.withSuccessHandler(() => { showLoading(false); loadAdminData(); })[func](ids);
}

function downloadCSV() {
    const ids = Array.from(document.querySelectorAll('.admin-check:checked')).map(c => c.value);
    if(!ids.length) return alert('選択してください');
    showLoading(true, 'CSV作成中...');
    google.script.run.withSuccessHandler(data => {
        showLoading(false);
        const csvContent = data.map(row => row.map(c => { let s=String(c); return (s.includes(',')||s.includes('\n')) ? '"'+s.replace(/"/g,'""')+'"' : s; }).join(',')).join('\n');
        const bom = new Uint8Array([0xEF, 0xBB, 0xBF]), blob = new Blob([bom, csvContent], { type: 'text/csv' });
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = "kanjo_" + new Date().toISOString().slice(0,10) + ".csv";
        a.click();
        if(confirm('CSV出力を完了しました。\nステータスを「CSV出力済み」に更新してリストから除外しますか？')) {
            showLoading(true); google.script.run.withSuccessHandler(() => { showLoading(false); loadAdminData(); }).markAsExported(ids);
        }
    }).getDataForCSV(ids);
}

function loadPresidentData() { google.script.run.withSuccessHandler(d => {
    let h = "";
    d.forEach(r => {
        h += `<tr><td><input type="checkbox" class="pres-check" value="${r.id}"></td>
             <td><button class="btn btn-outline-primary btn-edit-unify" onclick="openEditFromHistory('${r.id}', false)"><i class="fas fa-search me-1"></i>確認</button></td>
             <td>${r.user}</td><td>${r.date}</td><td><b>${r.store}</b></td><td class="text-end fw-bold">¥${Number(r.amount).toLocaleString()}</td></tr>`;
    });
    document.getElementById('presidentBody').innerHTML = h || '<tr><td colspan="6" class="text-center py-4">なし</td></tr>';
}).getHistoryData({view:'president'}); }

function approveSelected() { const ids = Array.from(document.querySelectorAll('.pres-check:checked')).map(c => c.value); if(ids.length && confirm('承認しますか？')) { showLoading(true); google.script.run.withSuccessHandler(() => { showLoading(false); loadPresidentData(); }).approveBulk(ids); } }
function loadMasters() { google.script.run.withSuccessHandler(d => { document.getElementById('categoryList').innerHTML = d.accounts.map(a => `<option value="${a}">`).join(''); }).getMasters(); }
function showLoading(s, t) { document.getElementById('loadingOverlay').style.display = s ? 'flex' : 'none'; if(t) document.getElementById('loadingText').textContent = t; }

/* Statement Logic */
function handleStatementDrop(e) { e.preventDefault(); document.getElementById('statementDragZone').classList.remove('active'); appendStatementFiles(e.dataTransfer.files); }
function appendStatementFiles(fs) {
    Array.from(fs).forEach(f => {
        if(!statementFiles.some(p => p.name === f.name && p.size === f.size)) statementFiles.push(f);
    });
    renderStatementPending();
}
function renderStatementPending() {
    const c = document.getElementById('pendingStatementList'), a = document.getElementById('statementUploadActions');
    c.innerHTML = '';
    statementFiles.forEach((f, i) => {
        const reader = new FileReader(), d = document.createElement('div');
        d.className = 'thumbnail-item';
        reader.onload = e => { 
            d.innerHTML = `<img src="${e.target.result}"><button class="btn-remove-thumb" onclick="statementFiles.splice(${i},1);renderStatementPending();event.stopPropagation();">×</button>`; 
        };
        reader.readAsDataURL(f); c.appendChild(d);
    });
    document.getElementById('statementCount').textContent = statementFiles.length;
    a.style.display = statementFiles.length ? 'block' : 'none';
}
function clearStatementFiles() { statementFiles = []; renderStatementPending(); }
function startStatementAnalysis() {
    showLoading(true, '明細書解析・照合中...');
    Promise.all(statementFiles.map(f => new Promise(res => {
        const r = new FileReader();
        r.onload = e => {
            google.script.run.withSuccessHandler(() => res()).withFailureHandler(() => res())
            .uploadStatementAndAnalyze({base64:e.target.result.split(',')[1], mimeType:f.type});
        }; r.readAsDataURL(f);
    }))).then(() => {
        showLoading(false);
        statementFiles = []; renderStatementPending();
        loadStatementData();
    });
}
function loadStatementData() {
    const filter = document.getElementById('statementFilter').value;
    showLoading(true);
    google.script.run.withSuccessHandler(data => {
        showLoading(false);
        const tbody = document.getElementById('statementBody');
        if(!data || data.length === 0) { tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4">データはありません</td></tr>'; return; }
        
        let h = "";
        data.forEach(r => {
            let statusBadge = '<span class="badge bg-secondary">未照合</span>';
            let rowClass = 'statement-row-unmatched';
            let actions = '<small class="text-muted">候補なし</small>';

            if(r.status === '照合済') {
                statusBadge = '<span class="badge bg-success">照合済</span>';
                rowClass = 'statement-row-matched';
                actions = '<small class="text-success"><i class="fas fa-check me-1"></i>完了</small>';
            } else if(r.status === '候補あり' || (r.candidates && r.candidates.length > 0)) {
                statusBadge = '<span class="badge bg-warning text-dark">候補あり</span>';
                rowClass = 'statement-row-candidate';
                actions = r.candidates.map(c => 
                    `<button class="btn btn-sm btn-outline-success mb-1 w-100 text-start" title="${c.store}" onclick="linkData('${r.id}', '${c.id}')">
                       <i class="fas fa-link me-1"></i>${c.date} ¥${c.amount.toLocaleString()} (${c.user})
                     </button>`
                ).join('');
            }
            
            let cardInfo = r.card ? `下4桁: ${r.card}` : '';
            if(r.holder) cardInfo += `<br><small class="text-muted">${r.holder}</small>`;

            h += `<tr class="${rowClass}">
                <td>${r.date}</td>
                <td><b>${r.store}</b></td>
                <td class="text-end fw-bold">¥${r.amount.toLocaleString()}</td>
                <td><small>${cardInfo}</small></td>
                <td class="text-center">${statusBadge}</td>
                <td>${actions}</td>
            </tr>`;
        });
        tbody.innerHTML = h;
    }).getReconciliationData(filter);
}

function linkData(stmtId, rcptId) {
    if(!confirm('この領収書と明細を紐付けますか？\n（ステータスが「照合済」になります）')) return;
    showLoading(true, '紐付け中...');
    google.script.run.withSuccessHandler(res => {
        showLoading(false);
        if(res.success) {
            loadStatementData();
        } else {
            alert('エラーが発生しました');
        }
    }).linkStatementToReceipt(stmtId, rcptId);
}
